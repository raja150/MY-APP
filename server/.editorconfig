[*.cs]

# S4487: Unread "private" fields should be removed
dotnet_diagnostic.S4487.severity = silent
csharp_indent_braces=false
csharp_indent_block_contents=true
insert_final_newline=true
dotnet_diagnostic.CA3076.severity=suggestion
dotnet_diagnostic.CA3077.severity=suggestion
dotnet_diagnostic.CA1507.severity=warning

# CA1822: Mark members as static
dotnet_diagnostic.CA1822.severity = none

# CA1067: Override Object.Equals(object) when implementing IEquatable<T>
dotnet_diagnostic.CA1067.severity = silent

# S101: Types should be named in PascalCase
dotnet_diagnostic.S101.severity = silent

[*.{cs,vb}]
dotnet_code_quality_unused_parameters=all:warning
indent_style=tab
dotnet_diagnostic.CA1805.severity=warning
dotnet_diagnostic.CA1838.severity=suggestion
dotnet_diagnostic.CA5397.severity=suggestion
dotnet_diagnostic.CA1707.severity=none
dotnet_diagnostic.CA1708.severity=suggestion
dotnet_diagnostic.CA1710.severity=silent
dotnet_diagnostic.CA1712.severity=suggestion
dotnet_diagnostic.CA1716.severity=warning
dotnet_diagnostic.CA1720.severity=suggestion
dotnet_diagnostic.CA1725.severity=suggestion

# Default severity for analyzer diagnostics with category 'Minor Code Smell'
dotnet_analyzer_diagnostic.category-Minor Code Smell.severity = silent
