namespace TranSmart.Service.Payroll
{
	public interface IDeclarationService : IBaseService<Declaration>
	{
		Task<IEnumerable<Declaration>> Declaration(Guid Id);
		Task<Declaration> GetDeclaration(Guid financialId, Guid empId);
		Task<DeclarationSetting> GetDeclarationSettings(Guid settingId);
		Task<DeclarationSetting> GetSettings(Guid financialYearId);
		bool IsDeclarationHasData(Declaration item);
		void ClearInputData(Declaration item);
		int HRATotal(DateTime rentalFrom, DateTime rentalTo, int amount);
		Task HRAUpdate(Declaration item, Declaration declaration);
		Task HomeLoanPay(Declaration item, Declaration declaration);
		Task LetOutProperty(Declaration item, Declaration declaration);
		Task Section6A80(Declaration item, Declaration declaration);
		Task Section6A80D(Declaration item, Declaration declaration);
		Task PreviousEmployment(Declaration item, Declaration declaration);
		Task<Guid> GetEmployeeStateId(Guid employeeId);
		Task OtherIncome(Declaration item, Declaration declaration);
		Task SectionOther(Declaration item, Declaration declaration);
	}
	public class DeclarationService : BaseService<Declaration>, IDeclarationService
	{
		public DeclarationService(IUnitOfWork uow) : base(uow)
		{

		}

		public async Task<DeclarationSetting> GetDeclarationSettings(Guid settingId)
		{
			return await UOW.GetRepositoryAsync<DeclarationSetting>().SingleAsync(x => x.PaySettingsId == settingId);
		}
		public async Task<DeclarationSetting> GetSettings(Guid financialYearId)
		{
			FinancialYear year = await UOW.GetRepositoryAsync<FinancialYear>().SingleAsync(x => x.ID == financialYearId);
			return await UOW.GetRepositoryAsync<DeclarationSetting>().SingleAsync(x => x.PaySettingsId == year.PaySettingsId);
		}
		public async Task<IEnumerable<Declaration>> Declaration(Guid Id)
		{
			return await UOW.GetRepositoryAsync<Declaration>().GetAsync(x => x.FinancialYearId == Id,
		   include: o => o.Include(x => x.Employee).ThenInclude(x => x.Designation)
					.Include(x => x.Employee).ThenInclude(x => x.Department));

		}

		public override async Task CustomValidation(Declaration item, Result<Declaration> result)
		{
			ClearInputData(item);

			//Declaration data is required for only old regime 
			if (!IsDeclarationHasData(item) && !item.IsNewRegime)
			{
				result.AddMessageItem(new MessageItem("No data to save.", FeedbackType.Error));
			}
			IEnumerable<HraDeclaration> hrs = item.HRALines.GetOverlappedTimes(item.HRALines, x => x.RentalFrom, x => x.RentalTo);
			if (hrs.Any())
			{
				result.AddMessageItem(new MessageItem("Duplicates are not allowed in HRA declaration.", FeedbackType.Error));
			}
			else if (item.Section80CLines.HasDuplicate(x => x.Section80CId))
			{
				result.AddMessageItem(new MessageItem("Duplicates are not allowed in section 80C.", FeedbackType.Exception));
				return ;
			}
			else if (item.Section80DLines.HasDuplicate(x => x.Section80DId))
			{
				result.AddMessageItem(new MessageItem("Duplicates are not allowed in section 80D.", FeedbackType.Exception));
			}
			else if (item.SectionOtherLines.HasDuplicate(x => x.OtherSectionsId))
			{
				result.AddMessageItem(new MessageItem("Duplicates are not allowed in other investment.", FeedbackType.Exception));
			}
			//Validate declaration already submitted
			if (await UOW.GetRepositoryAsync<Declaration>().HasRecordsAsync(x => x.EmployeeId == item.EmployeeId
				&& x.FinancialYearId == item.FinancialYearId
				&& x.ID != item.ID))
			{
				result.AddMessageItem(new MessageItem(Resource.Declaration_Already_Submitted));
			}

			var financialYear = await UOW.GetRepositoryAsync<FinancialYear>().SingleAsync(x => x.ID == item.FinancialYearId);
			if (financialYear != null && financialYear.Closed)
			{
				result.AddMessageItem(new MessageItem(Resource.The_selected_financial_year_is_closed, FeedbackType.Error));
			}
			if (item.HRALines.Any()
				&& (item.HRALines.Any(x => x.RentalFrom < financialYear.FromDate && x.RentalTo > financialYear.ToDate)
				|| item.HRALines.Any(x => x.RentalFrom > x.RentalTo)))
			{
				result.AddMessageItem(new MessageItem(Resource.HRA_Invalid_From__And_To_Dates, FeedbackType.Error));
			}
			var payrunsettings = await UOW.GetRepositoryAsync<DeclarationSetting>().SingleAsync();
			if (item.Section80CLines.Sum(x => x.Amount) > payrunsettings.MaxLimitEightyC)
			{
				result.AddMessageItem(new MessageItem("Declaration setting maximum limit of 80C crossed"));
			}
			if (item.Section80DLines.Sum(x => x.Amount) > payrunsettings.MaxLimitEightyD)
			{
				result.AddMessageItem(new MessageItem("Declaration setting maximum limit of 80D crossed"));
			}
			if (item.HomeLoanPay != null && item.HomeLoanPay.InterestPaid > payrunsettings.HouseLoanInt)
			{
				result.AddMessageItem(new MessageItem("Declaration setting maximum Home loan limit crossed"));
			}
		}

		public bool IsDeclarationHasData(Declaration item)
		{
			//Check declaration having data to save 
			return item.HRALines.Any()
							|| item.HomeLoanPay != null && item.HomeLoanPay.InterestPaid > 0
							|| item.LetOutPropertyLines.Any()
							|| item.Section80CLines.Any()
							|| item.Section80DLines.Any()
							|| item.SectionOtherLines.Any()
							|| item.IncomeSource != null && (item.IncomeSource.OtherSources > 0
							|| item.IncomeSource.InterestOnFD > 0
							|| item.IncomeSource.InterestOnSaving > 0)
							|| item.PrevEmployment != null && (item.PrevEmployment.IncomeAfterException > 0
							|| item.PrevEmployment.IncomeTax > 0
							|| item.PrevEmployment.ProfessionalTax > 0
							|| item.PrevEmployment.ProvisionalFund > 0
							|| item.PrevEmployment.EncashmentExceptions > 0);
		}

		public void ClearInputData(Declaration item)
		{
			item.Section80CLines = item.Section80CLines == null ? new List<Section6A80C>()
				: item.Section80CLines.Where(x => x.Amount > 0).ToList();
			item.Section80DLines = item.Section80DLines == null ? new List<Section6A80D>()
				: item.Section80DLines.Where(x => x.Amount > 0).ToList();
			item.SectionOtherLines = item.SectionOtherLines == null ? new List<Section6AOther>()
				: item.SectionOtherLines.Where(x => x.Amount > 0).ToList();
			item.LetOutPropertyLines = item.LetOutPropertyLines == null ? new List<LetOutProperty>()
				: item.LetOutPropertyLines.Where(x => x.NetAnnualValue > 0).ToList();
			item.HRALines = item.HRALines == null ? new List<HraDeclaration>()
				: item.HRALines.Where(x => x.Amount > 0).ToList();

			if (item.IncomeSource != null && item.IncomeSource.NoDataToSave())
			{
				item.IncomeSource = null;
			}
			if (item.HomeLoanPay != null && item.HomeLoanPay.NoDataToSave())
			{
				item.HomeLoanPay = null;
			}
			if (item.PrevEmployment != null && item.PrevEmployment.IncomeAfterException == 0)
			{
				item.PrevEmployment = null;
			}
		}

		public override async Task<Result<Declaration>> AddAsync(Declaration item)
		{
			var result = new Result<Declaration>();
			await CustomValidation(item, result);
			if (result.HasNoError)
			{
				foreach (HraDeclaration hraItem in item.HRALines)
				{
					//Find HRA total for each rent details
					hraItem.Total = HRATotal(hraItem.RentalFrom, hraItem.RentalTo, hraItem.Amount);
				}

				var medicalSec = await UOW.GetRepositoryAsync<Section80D>().GetAsync(x => x.Status);
				foreach (var medical in item.Section80DLines)
				{
					var selected = medicalSec.FirstOrDefault(x => x.ID == medical.Section80DId);
					//Update limit amount
					medical.Qualified = selected == null ? 0 : Math.Min(selected.Limit, medical.Amount);

					//Update Amount
					medical.Amount = selected == null ? 0 : medical.Amount;
				}

				var otherSec = await UOW.GetRepositoryAsync<OtherSections>().GetAsync(x => x.Status);
				foreach (var other in item.SectionOtherLines)
				{
					var selected = otherSec.FirstOrDefault(x => x.ID == other.OtherSectionsId);
					//Update limit amount
					other.Qualified = selected == null ? 0 : Math.Min(selected.Limit, other.Amount);

					//Update Amount
					other.Amount = selected == null ? 0 : other.Amount;
				}

				//Add to database
				result = await AddOnlyAsync(item);

				if (result.HasNoError)
				{
					DeclarationSetting settings = await UOW.GetRepositoryAsync<DeclarationSetting>().SingleAsync();

					//Employees salary details for paid months in current fiscal year
					var paySheets = (await UOW.GetRepositoryAsync<PaySheet>().GetAsync(x => x.EmployeeID == item.EmployeeId && x.PayMonth.FinancialYearId == item.FinancialYearId,
					   include: o => o.Include(x => x.Earnings).ThenInclude(x => x.Component))).ToList();

					//Salary released months
					int paidMonths = await UOW.GetRepositoryAsync<PayMonth>().GetCountAsync(x => x.FinancialYearId == item.FinancialYearId
					&& (x.Status == (int)PayMonthStatus.Released));
					Guid employeeStateId = await GetEmployeeStateId(item.EmployeeId);
					//Income tax calculation depending on regime

					Salary salaryItem = await UOW.GetRepositoryAsync<Salary>().SingleAsync(x => x.EmployeeId == item.EmployeeId,
					include: x => x.Include(o => o.Earnings).ThenInclude(o => o.Component)
					.Include(o => o.Deductions).ThenInclude(o => o.Deduction));
					var _financialYear = await UOW.GetRepositoryAsync<FinancialYear>().SingleAsync(x => x.ID == item.FinancialYearId);
					var _taxCalculator = new IncomeTaxCalculator(UOW, _financialYear);
					await _taxCalculator.Calculate(salaryItem, paySheets, item, settings, employeeStateId, paidMonths, true);

					//Update declaration
					UOW.GetRepositoryAsync<Declaration>().UpdateAsync(item);
					await UOW.SaveChangesAsync();
					result.IsSuccess = true;
				}
			}

			return result;
		}

		public async Task<Guid> GetEmployeeStateId(Guid employeeId)
		{
			var employee = await UOW.GetRepositoryAsync<Employee>().SingleAsync(x => x.ID == employeeId,
									include: x => x.Include(y => y.WorkLocation));
			return employee == null || employee.WorkLocation == null ?
				Guid.Empty : employee.WorkLocation.StateId;
		}

		public override async Task<Result<Declaration>> UpdateAsync(Declaration item)
		{
			var result = new Result<Declaration>();
			await CustomValidation(item, result);

			DeclarationSetting settings = await UOW.GetRepositoryAsync<DeclarationSetting>().SingleAsync();
			settings ??= new DeclarationSetting();
			if (settings == null || settings.MaxLimitEightyC == 0 || settings.MaxLimitEightyD == 0)
			{
				result.AddMessageItem(new MessageItem(Resource.Please_Contact_Administrator));
			}
			if (result.HasError) return result;
			Declaration declaration = await UOW.GetRepositoryAsync<Declaration>().SingleAsync(x => x.ID == item.ID && x.EmployeeId == item.EmployeeId);
			if (declaration == null)
			{
				result.AddMessageItem(new MessageItem(Resource.Invalid_Declaration));
			}
			if (result.HasNoError)
			{
				await HRAUpdate(item, declaration);
				await HomeLoanPay(item, declaration);
				await LetOutProperty(item, declaration);
				await Section6A80(item, declaration);
				await Section6A80D(item, declaration);
				await SectionOther(item, declaration);
				await OtherIncome(item, declaration);
				await PreviousEmployment(item, declaration);

				try
				{
					await UOW.SaveChangesAsync();
					int paidMonths = await UOW.GetRepositoryAsync<PayMonth>().GetCountAsync(x => x.FinancialYearId == item.FinancialYearId
						&& (x.Status == (int)PayMonthStatus.Released));

					var paySheets = (await UOW.GetRepositoryAsync<PaySheet>().GetAsync(x => x.EmployeeID == item.EmployeeId
							&& x.PayMonth.FinancialYearId == item.FinancialYearId,
					   include: o => o.Include(x => x.Earnings).ThenInclude(x => x.Component))).ToList();

					Guid employeeStateId = await GetEmployeeStateId(item.EmployeeId);

					Salary salaryItem = await UOW.GetRepositoryAsync<Salary>().SingleAsync(x => x.EmployeeId == item.EmployeeId,
					include: x => x.Include(o => o.Earnings).ThenInclude(o => o.Component)
					.Include(o => o.Deductions).ThenInclude(o => o.Deduction));

					var _financialYear = await UOW.GetRepositoryAsync<FinancialYear>().SingleAsync(x => x.ID == item.FinancialYearId);
					var _taxCalculator = new IncomeTaxCalculator(UOW, _financialYear);

					await _taxCalculator.Calculate(salaryItem, paySheets, declaration, settings, employeeStateId, paidMonths, true);
					UOW.GetRepositoryAsync<Declaration>().UpdateAsync(declaration);
					await UOW.SaveChangesAsync();
					result.IsSuccess = true;
					result.ReturnValue = item;
				}
				catch (Exception ex)
				{
					result.AddMessageItem(new MessageItem(ex));
				}
			}
			return result;
		}
		public override async Task<Declaration> GetById(Guid id)
		{
			return await UOW.GetRepositoryAsync<Declaration>().SingleAsync(
				predicate: P => P.ID == id,
				include: i => i.Include(x => x.Employee).Include(x => x.Allowances).Include(x => x.FinancialYear)
				.Include(x => x.HRALines).Include(x => x.HomeLoanPay)
				.Include(x => x.LetOutPropertyLines).Include(x => x.Section80CLines).ThenInclude(x => x.Section80C)
				.Include(x => x.Section6A80CWagesCLines).ThenInclude(x => x.Component)
				.Include(x => x.Section80DLines).ThenInclude(x => x.Section80D)
				.Include(x => x.SectionOtherLines).ThenInclude(x => x.OtherSections)
				.Include(x => x.PrevEmployment).Include(x => x.IncomeSource));
		}
		public async Task<Declaration> GetDeclaration(Guid financialId, Guid empId)
		{
			return await UOW.GetRepositoryAsync<Declaration>().SingleAsync(
				predicate: P => P.EmployeeId == empId && P.FinancialYearId == financialId,
				include: i => i.Include(x => x.Employee).Include(x => x.HRALines).Include(x => x.HomeLoanPay)
			   .Include(x => x.LetOutPropertyLines).Include(x => x.Section80CLines).ThenInclude(x => x.Section80C)
			   .Include(x => x.Section80DLines).ThenInclude(x => x.Section80D)
			   .Include(x => x.SectionOtherLines).ThenInclude(x => x.OtherSections)
			   .Include(x => x.PrevEmployment).Include(x => x.IncomeSource)
			   .Include(x => x.Allowances).Include(x => x.FinancialYear));
		}
		public override async Task<IPaginate<Declaration>> GetPaginate(BaseSearch baseSearch)
		{
			return await UOW.GetRepositoryAsync<Declaration>().GetPaginateAsync(
			   predicate: x => (string.IsNullOrEmpty(baseSearch.Name) || x.Employee.Name.Contains(baseSearch.Name)),
			   orderBy: o => o.OrderByDescending(x => x.AddedAt),
			   include: i => i.Include(x => x.Employee).Include(x => x.FinancialYear),
			   index: baseSearch.Page, size: baseSearch.Size);
		}
		public int HRATotal(DateTime rentalFrom, DateTime rentalTo, int amount)
		{
			return DateUtil.GetMonthDifference(rentalFrom.Year, rentalFrom.Month, rentalTo.Year, rentalTo.Month) * amount;
		}
		public async Task HRAUpdate(Declaration item, Declaration declaration)
		{
			var hRAs = await UOW.GetRepositoryAsync<HraDeclaration>().GetAsync(x => x.DeclarationId == declaration.ID);

			//Update
			IEnumerable<HraDeclaration> intersectHRA = item.HRALines.Intersection(hRAs, (x, y) => x.ID == y.ID);
			foreach (HraDeclaration hraItem in intersectHRA)
			{
				hraItem.Total = HRATotal(hraItem.RentalFrom, hraItem.RentalTo, hraItem.Amount);
				HraDeclaration edit = hRAs.FirstOrDefault(x => x.ID == hraItem.ID);
				edit.Update(hraItem);
				UOW.GetRepositoryAsync<HraDeclaration>().UpdateAsync(edit);
			}

			//add
			IEnumerable<HraDeclaration> newHRA = item.HRALines.Exclude(hRAs, (x, y) => x.ID == y.ID);
			foreach (HraDeclaration hraItem in newHRA)
			{
				hraItem.DeclarationId = declaration.ID;
				hraItem.Total = HRATotal(hraItem.RentalFrom, hraItem.RentalTo, hraItem.Amount);
				await UOW.GetRepositoryAsync<HraDeclaration>().AddAsync(hraItem);
			}

			//Delete
			IEnumerable<HraDeclaration> removedHRA = hRAs.Exclude(item.HRALines, (x, y) => x.ID == y.ID);
			foreach (HraDeclaration hraItem in removedHRA)
			{
				UOW.GetRepositoryAsync<HraDeclaration>().DeleteAsync(hraItem);
			}
		}
		public async Task HomeLoanPay(Declaration item, Declaration declaration)
		{
			HomeLoanPay homeLoanPay = await UOW.GetRepositoryAsync<HomeLoanPay>().SingleAsync(x => x.DeclarationId == declaration.ID);

			//Delete data in database when user not enter home loan
			if (homeLoanPay != null && item.HomeLoanPay == null)
			{
				UOW.GetRepositoryAsync<HomeLoanPay>().DeleteAsync(homeLoanPay);
			}
			//Add home row data to declaration
			else if (homeLoanPay == null && item.HomeLoanPay != null)
			{
				item.HomeLoanPay.DeclarationId = declaration.ID;
				await UOW.GetRepositoryAsync<HomeLoanPay>().AddAsync(item.HomeLoanPay);
			}
			//update existing declaration
			else if (homeLoanPay != null)
			{
				homeLoanPay.Update(item.HomeLoanPay);
				UOW.GetRepositoryAsync<HomeLoanPay>().UpdateAsync(homeLoanPay);
			}
		}
		public async Task LetOutProperty(Declaration item, Declaration declaration)
		{
			var letOutProperties = await UOW.GetRepositoryAsync<LetOutProperty>().GetAsync(x => x.DeclarationId == declaration.ID);

			//Update
			IEnumerable<LetOutProperty> intersectLet = item.LetOutPropertyLines.Intersection(letOutProperties, (x, y) => x.ID == y.ID);
			foreach (LetOutProperty letItem in intersectLet)
			{
				LetOutProperty edit = letOutProperties.FirstOrDefault(x => x.ID == letItem.ID);
				edit.Update(letItem);
				UOW.GetRepositoryAsync<LetOutProperty>().UpdateAsync(edit);
			}

			//add
			IEnumerable<LetOutProperty> newLet = item.LetOutPropertyLines.Exclude(letOutProperties, (x, y) => x.ID == y.ID);
			foreach (LetOutProperty letItem in newLet)
			{
				letItem.DeclarationId = declaration.ID;
				await UOW.GetRepositoryAsync<LetOutProperty>().AddAsync(letItem);
			}

			//Delete
			IEnumerable<LetOutProperty> removedLet = letOutProperties.Exclude(item.LetOutPropertyLines, (x, y) => x.ID == y.ID);
			foreach (LetOutProperty hraItem in removedLet)
			{
				UOW.GetRepositoryAsync<LetOutProperty>().DeleteAsync(hraItem);
			}
		}
		public async Task Section6A80(Declaration item, Declaration declaration)
		{
			var section6A80Cs = await UOW.GetRepositoryAsync<Section6A80C>().GetAsync(x => x.DeclarationId == declaration.ID);

			//Update
			IEnumerable<Section6A80C> intersect80c = item.Section80CLines.Intersection(section6A80Cs, (x, y) => x.Section80CId == y.Section80CId);
			foreach (Section6A80C letItem in intersect80c)
			{
				Section6A80C edit = section6A80Cs.FirstOrDefault(x => x.Section80CId == letItem.Section80CId);
				edit.Update(letItem);
				UOW.GetRepositoryAsync<Section6A80C>().UpdateAsync(edit);
			}

			//add
			IEnumerable<Section6A80C> new80c = item.Section80CLines.Exclude(section6A80Cs, (x, y) => x.Section80CId == y.Section80CId);
			foreach (Section6A80C letItem in new80c)
			{
				letItem.DeclarationId = declaration.ID;
				await UOW.GetRepositoryAsync<Section6A80C>().AddAsync(letItem);
			}

			//Delete
			IEnumerable<Section6A80C> removed80c = section6A80Cs.Exclude(item.Section80CLines, (x, y) => x.Section80CId == y.Section80CId);
			foreach (Section6A80C hraItem in removed80c)
			{
				UOW.GetRepositoryAsync<Section6A80C>().DeleteAsync(hraItem);
			}
		}
		public async Task Section6A80D(Declaration item, Declaration declaration)
		{
			var section6A80Ds = await UOW.GetRepositoryAsync<Section6A80D>().GetAsync(x => x.DeclarationId == declaration.ID,
								include: o => o.Include(x => x.Section80D));

			//Update
			IEnumerable<Section6A80D> intersect80d = item.Section80DLines.Intersection(section6A80Ds, (x, y) => x.Section80DId == y.Section80DId);
			foreach (Section6A80D letItem in intersect80d)
			{
				Section6A80D edit = section6A80Ds.FirstOrDefault(x => x.Section80DId == letItem.Section80DId);
				edit.Update(letItem);
				edit.Qualified = Math.Min(edit.Section80D.Limit, edit.Amount);
				UOW.GetRepositoryAsync<Section6A80D>().UpdateAsync(edit);
			}

			//add
			IEnumerable<Section6A80D> new80d = item.Section80DLines.Exclude(section6A80Ds, (x, y) => x.Section80DId == y.Section80DId);
			foreach (Section6A80D letItem in new80d)
			{
				Section80D secD = await UOW.GetRepositoryAsync<Section80D>().SingleAsync(x => x.ID == letItem.Section80DId);
				letItem.DeclarationId = declaration.ID;
				letItem.Qualified = Math.Min(secD != null ? secD.Limit : 0, letItem.Amount);
				await UOW.GetRepositoryAsync<Section6A80D>().AddAsync(letItem);
			}

			//Delete
			IEnumerable<Section6A80D> removed80d = section6A80Ds.Exclude(item.Section80DLines, (x, y) => x.Section80DId == y.Section80DId);
			foreach (Section6A80D hraItem in removed80d)
			{
				UOW.GetRepositoryAsync<Section6A80D>().DeleteAsync(hraItem);
			}
		}
		public async Task SectionOther(Declaration item, Declaration declaration)
		{
			var sectionOthers = await UOW.GetRepositoryAsync<Section6AOther>().GetAsync(x => x.DeclarationId == declaration.ID);
			var otherSections = await UOW.GetRepositoryAsync<OtherSections>().GetAsync();


			//Update
			IEnumerable<Section6AOther> intersectOth = item.SectionOtherLines.Intersection(sectionOthers, (x, y) => x.OtherSectionsId == y.OtherSectionsId);
			foreach (Section6AOther letItem in intersectOth)
			{
				Section6AOther edit = sectionOthers.FirstOrDefault(x => x.OtherSectionsId == letItem.OtherSectionsId);
				OtherSections oth = otherSections.FirstOrDefault(x => x.ID == letItem.OtherSectionsId);
				if (oth != null)
				{
					edit.Amount = letItem.Amount;
					edit.Qualified = Math.Min(oth.Limit, letItem.Amount);
					UOW.GetRepositoryAsync<Section6AOther>().UpdateAsync(edit);
				}
			}

			//add
			IEnumerable<Section6AOther> newOth = item.SectionOtherLines.Exclude(sectionOthers, (x, y) => x.OtherSectionsId == y.OtherSectionsId);
			foreach (Section6AOther letItem in newOth)
			{
				OtherSections oth = otherSections.FirstOrDefault(x => x.ID == letItem.OtherSectionsId);
				if (oth != null)
				{
					letItem.Qualified = Math.Min(oth.Limit, letItem.Amount);
					letItem.DeclarationId = declaration.ID;
					await UOW.GetRepositoryAsync<Section6AOther>().AddAsync(letItem);
				}
			}

			//Delete
			IEnumerable<Section6AOther> removedOth = sectionOthers.Exclude(item.SectionOtherLines, (x, y) => x.OtherSectionsId == y.OtherSectionsId);
			foreach (Section6AOther hraItem in removedOth)
			{
				UOW.GetRepositoryAsync<Section6AOther>().DeleteAsync(hraItem);
			}
		}
		public async Task OtherIncome(Declaration item, Declaration declaration)
		{
			var otherIncomeSource = await UOW.GetRepositoryAsync<OtherIncomeSources>().SingleAsync(x => x.DeclarationId == declaration.ID);

			//Delete data in database when user not enter other income source
			if (otherIncomeSource != null && item.IncomeSource == null)
			{
				UOW.GetRepositoryAsync<OtherIncomeSources>().DeleteAsync(otherIncomeSource);
			}
			//Add other income source data to declaration
			else if (otherIncomeSource == null && item.IncomeSource != null)
			{
				item.IncomeSource.DeclarationId = declaration.ID;
				await UOW.GetRepositoryAsync<OtherIncomeSources>().AddAsync(item.IncomeSource);
			}
			//update existing declaration
			else if (otherIncomeSource != null)
			{
				otherIncomeSource.Update(item.IncomeSource);
				UOW.GetRepositoryAsync<OtherIncomeSources>().UpdateAsync(otherIncomeSource);
			}
		}
		public async Task PreviousEmployment(Declaration item, Declaration declaration)
		{
			PrevEmployment prevEmployment = await UOW.GetRepositoryAsync<PrevEmployment>().SingleAsync(x => x.DeclarationId == declaration.ID);

			//Delete data in database when user not enter other income source
			if (prevEmployment != null && item.PrevEmployment == null)
			{
				UOW.GetRepositoryAsync<PrevEmployment>().DeleteAsync(prevEmployment);
			}
			//Add other income source data to declaration
			else if (prevEmployment == null && item.PrevEmployment != null)
			{
				item.PrevEmployment.DeclarationId = declaration.ID;
				await UOW.GetRepositoryAsync<PrevEmployment>().AddAsync(item.PrevEmployment);
			}
			//update existing declaration
			else if (prevEmployment != null)
			{
				prevEmployment.Update(item.PrevEmployment);
				UOW.GetRepositoryAsync<PrevEmployment>().UpdateAsync(prevEmployment);
			}
		}
	}
}
