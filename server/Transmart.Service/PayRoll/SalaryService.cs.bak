		public override async Task<Salary> GetById(Guid id)
		{
			return await UOW.GetRepositoryAsync<Salary>().SingleAsync(
				predicate: p => p.ID == id,
				include: i => i.Include(x => x.Employee).Include(X => X.Deductions)
				.Include(x => x.Earnings).ThenInclude(x => x.Component)
				.Include(x => x.Earnings).ThenInclude(x => x.PercentOnComp));
		}
		public override async Task<IPaginate<Salary>> GetPaginate(BaseSearch baseSearch)
		{
			return await UOW.GetRepositoryAsync<Salary>().GetPageListAsync(
			   predicate: x => ((string.IsNullOrEmpty(baseSearch.Name) || x.Employee.No.Contains(baseSearch.Name)) ||
			   (string.IsNullOrEmpty(baseSearch.Name) || x.Employee.Name.Contains(baseSearch.Name))),
			   include: i => i.Include(x => x.Employee).ThenInclude(x => x.Department)
			   .Include(x => x.Employee).ThenInclude(x => x.Designation),
			   index: baseSearch.Page, size: baseSearch.Size, sortBy: baseSearch.SortBy ?? "Employee.Name", ascending: !baseSearch.IsDescend);
		}

		public async Task<IEnumerable<TemplateEarning>> GetTemplateComponents(Guid templateId)
		{
			return await UOW.GetRepositoryAsync<TemplateEarning>().GetAsync(
				predicate: p => p.TemplateId == templateId,
				include: i => i.Include(x => x.PercentOnComp).Include(x => x.Component),
				orderBy: o => o.OrderByDescending(x => x.AddedAt));
		}
		public override async Task OnBeforeAdd(Salary item, Result<Salary> executionResult)
		{
			if (!executionResult.HasError)
			{
				Salary empSalary = await UOW.GetRepositoryAsync<Salary>().SingleAsync(x => x.EmployeeId == item.EmployeeId);
				if (empSalary != null)
				{
					executionResult.AddMessageItem(new MessageItem(
						nameof(Salary.EmployeeId), Resource.Employee_Salary_Already_Available));
				}
			}
			await base.OnBeforeAdd(item, executionResult);
		}

		public async Task<Salary> EmpSalary(Guid EmpId)
		{
			return await UOW.GetRepositoryAsync<Salary>().SingleAsync(x => x.EmployeeId == EmpId,
			  include: x => x.Include(x => x.Employee).Include(x => x.Earnings).ThenInclude(x => x.Component)
				 .Include(x => x.Earnings).ThenInclude(x => x.PercentOnComp).Include(X => X.Deductions));
		}

		public override Task CustomValidation(Salary item, Result<Salary> result)
		{
			if (item.Monthly == 0)
			{
				result.AddMessageItem(new MessageItem(
					   nameof(Salary.EmployeeId), Resource.Monthly_Salary_Should_Be_MoreThen_Zero));
			}
			return base.CustomValidation(item, result);
		}

	}
}
