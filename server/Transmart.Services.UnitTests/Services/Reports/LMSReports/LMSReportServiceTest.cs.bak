		[Fact]
		public async Task AllEmployeeContactDetails_Report()
		{
			// Arrenge
			var fromDate = DateTime.Parse("2020-08-01"); var toDate = DateTime.Parse("2020-08-31");
			var employee = _employeeData.GetEmployeeData();
			IEnumerable<EmployeeFamily> families = new List<EmployeeFamily>
			{
				new EmployeeFamily
				{
					EmployeeId = employee.ID,
					Employee = employee,
					ContactNo="9654321870",
					HumanRelation=1,
				}
			};
			// Mock
			var mockEmpFamilies = families.AsQueryable().BuildMockDbSet();
			_context.Setup(x => x.Set<EmployeeFamily>()).Returns(mockEmpFamilies.Object);
			var repository = new RepositoryAsync<EmployeeFamily>(_context.Object);
			uow.Setup(m => m.GetRepositoryAsync<EmployeeFamily>()).Returns(repository);

			// Act
			var dd = await _reportService.AllEmployeeContactDetails(employee.DepartmentId, employee.DesignationId, employee.TeamId, employee.ID, fromDate, toDate);
			//Assert
			Assert.True(dd.Count() == 1);
		}

		[Fact]
		public async Task ResignedEmployees_Report()
		{
			#region Arrenge
			var fromDate = DateTime.Parse("2020-08-01"); var toDate = DateTime.Parse("2020-08-31");
			var employee = _employeeData.GetEmployeeData();
			var employees = _employeeData.GetAllEmployeesData();
			IEnumerable<EmployeeResignation> resignations = new List<EmployeeResignation>
			{
				new EmployeeResignation
				{
					EmployeeId = employee.ID,
					Employee = employee,
					ResignationOn = DateTime.Parse("2020-08-22"),
				},
				new EmployeeResignation
				{
					EmployeeId = employees.LastOrDefault().ID,
					Employee = employees.LastOrDefault(),
					ResignationOn = DateTime.Parse("2020-08-02"),
				}
			};
			#endregion
			// Mock
			var mockResignedEmps = resignations.AsQueryable().BuildMockDbSet();
			_context.Setup(x => x.Set<EmployeeResignation>()).Returns(mockResignedEmps.Object);
			var repository = new RepositoryAsync<EmployeeResignation>(_context.Object);
			uow.Setup(m => m.GetRepositoryAsync<EmployeeResignation>()).Returns(repository);

			// Act
			var dd = await _reportService.ResignedEmployees(employee.DepartmentId, employee.DesignationId, employee.TeamId, employee.ID, fromDate, toDate);
			// Assert
			Assert.True(dd.Count() == 1);
		}

		[Fact]
		public async Task EmployeeEmergencyAddress_Report()
