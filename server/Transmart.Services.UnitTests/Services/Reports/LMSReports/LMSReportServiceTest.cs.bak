			var employees = _employeeData.GetAllEmployeesData();
			IEnumerable<EmployeeEmergencyAd> emergencyAds = new List<EmployeeEmergencyAd>
			{
				new EmployeeEmergencyAd
				{
					EmployeeId = employee.ID,
					Employee = employee,
					AddressLineOne="Yellareddy Guda",
					EmergencyConNo = "8956237845",
					Country = "India",
				},
				new EmployeeEmergencyAd
				{
					EmployeeId = employees.LastOrDefault().ID,
					Employee = employees.LastOrDefault(),
					AddressLineOne="California",
					EmergencyConNo = "040-123456892",
					Country = "USA",
				}
			};
			// Mock
			var mockEmergencyAds = emergencyAds.AsQueryable().BuildMockDbSet();
			_context.Setup(x => x.Set<EmployeeEmergencyAd>()).Returns(mockEmergencyAds.Object);
			var repository = new RepositoryAsync<EmployeeEmergencyAd>(_context.Object);
			uow.Setup(m => m.GetRepositoryAsync<EmployeeEmergencyAd>()).Returns(repository);
			// Act
			var dd = await _reportService.EmployeeEmergencyAddress(employee.DepartmentId, employee.DesignationId, employee.TeamId, employee.ID, fromDate, toDate, 2);
			// Assert
			Assert.True(dd.Count() == 1);
		}

