		[Fact]
		public async Task SelfAttendance_Report()
		{
			// Arrenge
			var employee = _employeeData.GetEmployeeData();
			IEnumerable<Attendance> attendenceData = new List<Attendance>
			{
				new Attendance
				{
					ID = Guid.NewGuid(),
					EmployeeId = employee.ID,
					Employee = employee,
					AttendanceDate = DateTime.Now.AddDays(-4),
					AttendanceStatus = 1,
					InTime= DateTime.Now.AddDays(-4),
					OutTime =  DateTime.Now.AddDays(-4).AddHours(6),
				},
				new Attendance
				{
					ID = Guid.NewGuid(),
					EmployeeId = employee.ID,
					Employee = employee,
					AttendanceDate = DateTime.Now,
					AttendanceStatus = 2,
					InTime= DateTime.Now.AddDays(-4),
					OutTime =  DateTime.Now.AddDays(-4).AddHours(6),
				}
			};
			// Mock
			var mockAttendance = attendenceData.AsQueryable().BuildMockDbSet();
			_context.Setup(x => x.Set<Attendance>()).Returns(mockAttendance.Object);
			var repository = new RepositoryAsync<Attendance>(_context.Object);
			uow.Setup(m => m.GetRepositoryAsync<Attendance>()).Returns(repository);
			// Act
			var dd = await _reportService.SelfAttendance(DateTime.Now.AddDays(-5), DateTime.Now.AddDays(1), (int)AttendanceStatus.Present, employee.ID);
			//Assert
			Assert.True(dd.Count() == 1);
		}

		[Fact]
		public async Task AllActiveEmplyees_Report()
		{
			// Arrenge
			var fromDate = DateTime.Parse("2020-08-01"); var toDate = DateTime.Parse("2020-08-31");
			var dob = DateTime.Parse("1989-02-02");
			var employee = _employeeData.GetEmployeeData();
			var employees = _employeeData.GetAllEmployeesData();
			var resignedEmployees = new List<EmployeeResignation>() { new EmployeeResignation { ID = Guid.NewGuid() , EmployeeId = employees.LastOrDefault().ID } };

			// Mock
			var mockEmployees = employees.AsQueryable().BuildMockDbSet();
			_context.Setup(x => x.Set<Employee>()).Returns(mockEmployees.Object);
			var repository = new RepositoryAsync<Employee>(_context.Object);
			uow.Setup(m => m.GetRepositoryAsync<Employee>()).Returns(repository);

			var mockResignedEmps = resignedEmployees.AsQueryable().BuildMockDbSet();
			_context.Setup(x => x.Set<EmployeeResignation>()).Returns(mockResignedEmps.Object);
			var repo = new RepositoryAsync<EmployeeResignation>(_context.Object);
			uow.Setup(m => m.GetRepositoryAsync<EmployeeResignation>()).Returns(repo);

			var acticeEmpModel = new ActiveEmployeeRptModel
			{
				EmployeeId = employee.ID,
				DepartmentId = employee.DepartmentId,
				DesignationId = employee.DesignationId,
				EmpCategoryId = employee.EmpCategoryId,
				TeamId = employee.TeamId,
				DateOfBirth = dob,
				FromDate = fromDate,
				ToDate = toDate,
				WorkTypeId = employee.WorkTypeId
			};
			// Act
			var dd = await _reportService.AllActiveEmployees(acticeEmpModel);
			//Assert
			Assert.True(dd.Count() == 1);
		}

